{
  "compilerOptions": {
    "target": "ES2017",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["drizzle.config.ts", "scripts/**/*.ts", "vitest.config.ts", "vitest.core.config.ts"],
  "exclude": ["node_modules", "apps/web", "apps/widget"]
}
