# Verbose server logs (middleware, DB host only). Turn off after troubleshooting.
DEBUG=false

# Set to true to run the UI without Postgres (demo login: any email + password "admin").
# Do not use in production.
MOCK_DATA=false

# --- AWS data plane (no Supabase) ---
# Database: Amazon RDS for PostgreSQL or Aurora with pgvector enabled.
# Local dev: install Postgres 16+ with pgvector (e.g. Postgres.app, Homebrew), then point DATABASE_URL here.
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/DATABASE_NAME

# App URL — local:
NEXTAUTH_URL=http://localhost:3000
# Vercel: set to https://<your-project>.vercel.app or omit — the app sets NEXTAUTH_URL from VERCEL_URL when unset.
# Production: required (generate e.g. openssl rand -base64 32). Dev fallback exists only for local.
NEXTAUTH_SECRET=generate-a-long-random-string

# LLM APIs (OpenAI today; Bedrock can be wired behind the same orchestration layer)
OPENAI_API_KEY=
# Default chat model when a workspace has no override (Settings → AI in the app).
OPENAI_CHAT_MODEL=gpt-4o-mini

# WhatsApp Cloud API (Meta → your public HTTPS URL for /api/webhooks/whatsapp)
WHATSAPP_VERIFY_TOKEN=

# AWS region (ap-south-1 for India). On ECS/EC2, prefer IAM roles instead of static keys.
AWS_REGION=ap-south-1
# If not using IAM role (e.g. local dev with AWS CLI profile):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Human handoff email via Amazon SES
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Document originals: Amazon S3 (optional; uploads skip S3 if unset)
AWS_S3_BUCKET=
