# Verbose server logs (middleware, DB host only). Turn off after troubleshooting.
DEBUG=false

# Set to true to run the UI without Postgres (demo login: any email + password "admin").
# Do not use in production.
MOCK_DATA=false
#
# Switching to real data on the dashboard: set MOCK_DATA=false, set DATABASE_URL, run
# npm run db:push (and npm run db:seed or create an account via /signup), restart next dev,
# sign in — Clients, Chat logs, Analytics, etc. read from your database (empty tables OK).

# Local production build without DATABASE_URL: npm run build:local (forces MOCK_DATA=true for that command).

# Marketing site (optional): WhatsApp sales number as digits with country code, e.g. 9198XXXXXXXX
# NEXT_PUBLIC_WHATSAPP_SALES=
# NEXT_PUBLIC_SUPPORT_EMAIL=hello@yourdomain.com
# NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/yourcompany

# --- Database (Postgres) ---
# Fast path: Supabase → Project Settings → Database → copy URI (use pooler/port 6543 for Vercel serverless).
# Enable pgvector in Supabase SQL: CREATE EXTENSION IF NOT EXISTS vector;
# Local dev: Postgres 16+ with pgvector, or point at Supabase from .env.local.
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/DATABASE_NAME

# --- Supabase JS client (optional) ---
# Same project as DATABASE_URL. Used when you call getSupabaseBrowserClient() (Auth, Realtime, Storage).
# Dashboard → Project Settings → API: Project URL + publishable (or anon) key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Legacy name also supported: NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- AWS (optional; skip for Vercel + Supabase) ---
# S3 uploads / SES email — only if you configure AWS_* below.

# App URL — local:
NEXTAUTH_URL=http://localhost:3000
# Vercel: set to https://<your-project>.vercel.app or omit — the app sets NEXTAUTH_URL from VERCEL_URL when unset.
# Production: required (generate e.g. openssl rand -base64 32). Dev fallback exists only for local.
NEXTAUTH_SECRET=generate-a-long-random-string

# LLM APIs (OpenAI today; Bedrock can be wired behind the same orchestration layer)
OPENAI_API_KEY=
# Default chat model when a workspace has no override (Settings → AI in the app).
OPENAI_CHAT_MODEL=gpt-4o-mini

# WhatsApp Cloud API (Meta → your public HTTPS URL for /api/webhooks/whatsapp)
WHATSAPP_VERIFY_TOKEN=

# AWS region (ap-south-1 for India). On ECS/EC2, prefer IAM roles instead of static keys.
AWS_REGION=ap-south-1
# If not using IAM role (e.g. local dev with AWS CLI profile):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Human handoff email via Amazon SES
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Document originals: Amazon S3 (optional; uploads skip S3 if unset)
AWS_S3_BUCKET=
