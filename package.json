{
  "name": "chatbot-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "build": "npm run build -w @chatbot/web",
    "build:local": "npm run build:local -w @chatbot/web",
    "start": "npm run start -w @chatbot/web",
    "lint": "npm run lint -w @chatbot/web",
    "test": "vitest run && vitest run -c vitest.core.config.ts",
    "test:watch": "vitest --watch",
    "test:core": "vitest run -c vitest.core.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:enable-pgvector": "npx tsx scripts/enable-pgvector.ts",
    "db:seed": "npx tsx scripts/seed.ts"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.6",
    "tsx": "^4.19.3",
    "typescript": "^5",
    "vitest": "^1.0.0"
  }
}
